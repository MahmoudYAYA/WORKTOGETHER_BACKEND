<Window x:Class="WORKTOGETHER.WPF.Views.InterventionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion des interventions" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Text="Liste des Interventions" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Tableau -->
        <DataGrid Grid.Row="1" 
                  x:Name="DgInterventions"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="LightGray">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Titre" Binding="{Binding Titre}" Width="150"/>
                <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="150"/>
                <DataGridTextColumn Header="Statut" Binding="{Binding StatutLabel}" Width="150"/>
                <DataGridTextColumn Header="Unité" Binding="{Binding Unite.NomUnite}" Width="150"/>
                <DataGridTextColumn Header="Date débute" Binding="{Binding DateDebut, StringFormat=dd/MM/yyyy}" Width="120"/>
                <DataGridTextColumn Header="Date fin" Binding="{Binding DateFin, StringFormat=dd/MM/yyyy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>