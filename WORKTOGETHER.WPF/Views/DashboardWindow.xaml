<Window x:Class="WORKTOGETHER.WPF.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Text="Dashboard" 
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Cartes statistiques -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Carte Clients -->
            <Border Grid.Column="0" Background="#2C3E7A" CornerRadius="8" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="👥 Clients" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="TxtNbClients" Text="0" Foreground="White" 
                               FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Carte Baies -->
            <Border Grid.Column="1" Background="#1A5276" CornerRadius="8" Margin="5,0,5,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="📦 Baies" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="TxtNbBaies" Text="0" Foreground="White" 
                               FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Carte Commandes payées -->
            <Border Grid.Column="2" Background="#1E8449" CornerRadius="8" Margin="5,0,5,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="✅ Commandes payées" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="TxtNbCommandes" Text="0" Foreground="White" 
                               FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Carte Tickets ouverts -->
            <Border Grid.Column="3" Background="#922B21" CornerRadius="8" Margin="10,0,0,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="🎫 Tickets ouverts" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="TxtNbTickets" Text="0" Foreground="White" 
                               FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tableaux -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Dernières commandes -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Dernières commandes" 
                           FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <DataGrid Grid.Row="1" x:Name="DgDernieresCommandes"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          AlternatingRowBackground="LightGray">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Numéro" Binding="{Binding NumeroCommande}" Width="120"/>
                        <DataGridTextColumn Header="Client" Binding="{Binding Client.Nom}" Width="100"/>
                        <DataGridTextColumn Header="Statut" Binding="{Binding StatutPaiement}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Tickets ouverts -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Tickets ouverts" 
                           FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <DataGrid Grid.Row="1" x:Name="DgTicketsOuverts"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          AlternatingRowBackground="LightGray">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Numéro" Binding="{Binding NumeroTicket}" Width="120"/>
                        <DataGridTextColumn Header="Sujet" Binding="{Binding Sujet}" Width="150"/>
                        <DataGridTextColumn Header="Priorité" Binding="{Binding Priorite}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>