<Window x:Class="WORKTOGETHER.WPF.Views.ModifierUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifier Utilisateur" Height="450" Width="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Modifier Utilisateur"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Nom *" FontWeight="Bold"/>
            <TextBox x:Name="TxtNom" Padding="8,5"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Prénom *" FontWeight="Bold"/>
            <TextBox x:Name="TxtPrenom" Padding="8,5"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Email *" FontWeight="Bold"/>
            <TextBox x:Name="TxtEmail" Padding="8,5"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Nouveau mot de passe (laisser vide pour ne pas changer)"
                       FontWeight="Bold"/>
            <PasswordBox x:Name="Password" Padding="8,5"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,0,0,10">
            <TextBlock Text="Rôle *" FontWeight="Bold"/>
            <ComboBox x:Name="CmbRole" Padding="8,5">
                <ComboBoxItem Content="Administrateur" Tag="ROLE_ADMIN"/>
                <ComboBoxItem Content="Comptable"      Tag="ROLE_COMPTABLE"/>
                <ComboBoxItem Content="Client"         Tag="ROLE_CLIENT"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler" Padding="15,8" Margin="0,0,10,0"
                    Click="BtnAnnuler_Click"/>
            <Button Content="💾 Sauvegarder" Padding="15,8"
                    Background="#2C3E7A" Foreground="White"
                    Click="BtnSauvegarder_Click"/>
        </StackPanel>
    </Grid>
</Window>