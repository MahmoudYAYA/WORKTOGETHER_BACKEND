<Window x:Class="WORKTOGETHER.WPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WorkTogether" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="50,0">

            <!-- Logo / Titre -->
            <TextBlock Text="WorkTogether" FontSize="28" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Administration" FontSize="13"
                       Foreground="#6b6b8a" HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- Email -->
            <TextBlock Text="Email" Foreground="#aaaaaa" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtEmail" Padding="12,8" Margin="0,0,0,20"
                     Background="#12121a" Foreground="White"
                     BorderBrush="#2a2a3a" BorderThickness="1"
                     CaretBrush="White"/>

            <!-- Mot de passe -->
            <TextBlock Text="Mot de passe" Foreground="#aaaaaa" Margin="0,0,0,5"/>
            <PasswordBox x:Name="TxtPassword" Padding="12,8" Margin="0,0,0,30"
                         Background="#12121a" Foreground="White"
                         BorderBrush="#2a2a3a" BorderThickness="1"/>

            <!-- Bouton connexion -->
            <Button Content="SE CONNECTER" Padding="12,10"
                    Background="#2C3E7A" Foreground="White"
                    BorderThickness="0" FontWeight="Bold"
                    Click="BtnLogin_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2C3E7A"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A5276"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Message erreur -->
            <TextBlock x:Name="TxtErreur" Foreground="#e74c3c"
                       Margin="0,15,0,0" TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- Footer -->
        <TextBlock Grid.Row="1" Text="© 2026 WorkTogether"
                   Foreground="#3a3a5a" HorizontalAlignment="Center"
                   Margin="0,0,0,15" FontSize="11"/>
    </Grid>
</Window>