<Window x:Class="WORKTOGETHER.WPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WorkTogether - Connexion"
        Height="400" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#1a1a2e">
        <StackPanel VerticalAlignment="Center" Margin="50">

           
            <TextBlock Text="WorkTogether"
                       FontSize="28" FontWeight="Bold"
                       Foreground="#6C63FF"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <!-- Email -->
            <TextBlock Text="Email" Foreground="White" Margin="0,0,0,5"/>
            <TextBox x:Name="txtEmail"
                     Height="40" Padding="10"
                     Background="#16213e"
                     Foreground="White"
                     BorderBrush="#6C63FF"
                     Margin="0,0,0,15"/>

            <!-- Mot de passe -->
            <TextBlock Text="Mot de passe" Foreground="White" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword"
                         Height="40" Padding="10"
                         Background="#16213e"
                         Foreground="White"
                         BorderBrush="#6C63FF"
                         Margin="0,0,0,20"/>

            <!-- Message erreur -->
            <TextBlock x:Name="txtErreur"
                       Foreground="#e74c3c"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"
                       Visibility="Collapsed"/>

            <!-- Bouton connexion -->
            <Button x:Name="btnConnexion"
                    Content="Se connecter"
                    Height="45"
                    Background="#6C63FF"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnConnexion_Click"/>
        </StackPanel>
    </Grid>
</Window>