<Page x:Class="WORKTOGETHER.WPF.Reservations.ReservationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Réservations">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

   
        <Border Grid.Row="0" Background="#2C3E7A" Padding="15,10">
            <TextBlock Text="RÉSERVATIONS" Foreground="White"
                       FontSize="14" FontWeight="Bold"/>
        </Border>

        <!-- Contenu : Liste et less Détail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

          
            <DataGrid Grid.Column="0" Margin="15"
                      x:Name="DgReservations"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionChanged="DgReservations_SelectionChanged"
                      AlternatingRowBackground="#F5F5F5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="CLIENT" Binding="{Binding Client.Nom}" Width="*"/>
                    <DataGridTextColumn Header="OFFRE" Binding="{Binding Offre.NomOffre}" Width="*"/>
                    <DataGridTextColumn Header="DATE DÉBUT" Binding="{Binding DateDebut, StringFormat=dd/MM/yyyy}" Width="110"/>
                    <DataGridTextColumn Header="DATE FIN" Binding="{Binding DateFin, StringFormat=dd/MM/yyyy}" Width="110"/>
                    <DataGridTextColumn Header="PRIX TOTAL" Binding="{Binding PrixTotal}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

   
            <Border Grid.Column="1" Background="#F8F9FA"
                    BorderBrush="#DDDDDD" BorderThickness="1,0,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Titre -->
                    <Border Grid.Row="0" Background="#2C3E7A"
                            Padding="10,8" Margin="0,0,0,15">
                        <TextBlock Text="DÉTAIL RÉSERVATION"
                                   Foreground="White" FontWeight="Bold"/>
                    </Border>

                    <!-- Infos -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,15">

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Client :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtClient" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Offre :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtOffre" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Date début :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtDateDebut" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Date fin :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtDateFin" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Prix total :" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtPrixTotal" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Margin="0,5,0,10"/>
                        <TextBlock x:Name="TxtNbUnites" FontWeight="Bold"
                                   Foreground="#2C3E7A"/>
                    </StackPanel>

                    <!-- Unités -->
                    <DataGrid Grid.Row="2" x:Name="DgUnites"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              AlternatingRowBackground="#F5F5F5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NUMÉRO" Binding="{Binding NumeroUnite}" Width="*"/>
                            <DataGridTextColumn Header="NOM" Binding="{Binding NomUnite}" Width="*"/>
                            <DataGridTextColumn Header="ÉTAT" Binding="{Binding Etat}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>