<Page x:Class="WORKTOGETHER.WPF.Offres.OffrePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Offers">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="#2C3E7A" Padding="15,10">
            <TextBlock Text="OFFERS" FontSize="14" FontWeight="Bold"/>

        </Border>

        <!-- Contenu -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- ── LISTE ── -->
            <Grid Grid.Column="0" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Boutons actions -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="BtnCreer" Content="CRÉER" Padding="12,6" Margin="0,0,5,0"
                            Background="#2C3E7A" Foreground="White" BorderThickness="0"
                            Click="BtnCreer_Click"/>
                    <Button x:Name="BtnModifier" Content="MODIFIER" Padding="12,6" Margin="0,0,5,0"
                            Background="#1A5276" Foreground="White" BorderThickness="0"
                            Click="BtnModifier_Click"/>
                    <Button x:Name="BtnSupprimer" Content="SUPPRIMER" Padding="12,6" Margin="0,0,5,0"
                            Background="#922B21" Foreground="White" BorderThickness="0"
                            Click="BtnSupprimer_Click"/>
                </StackPanel>

                <!-- Recherche -->
                <TextBox Grid.Row="1" x:Name="TxtRecherche"
                         Padding="8,5" Margin="0,0,0,10"
                         TextChanged="TxtRecherche_TextChanged"/>

                <!-- Liste -->
                <DataGrid Grid.Row="2" x:Name="DgOffers"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionChanged="DgOffers_SelectionChanged"
                          AlternatingRowBackground="#F5F5F5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nom offre" Binding="{Binding NomOffre}" Width="*"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Nombre Unite" Binding="{Binding NombreUnites}" Width="*"/>
                        <DataGridTextColumn Header="Prix mensuel" Binding="{Binding PrixMensuel}" Width="*"/>
                        <DataGridTextColumn Header="Prix annuelle" Binding="{Binding PrixAnnuelle}" Width="*"/>
                        <DataGridTextColumn Header="Réduction annuelle" Binding="{Binding ReductionAnnuelle}" Width="*"/>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ── FORMULAIRE ── -->
            <Border Grid.Column="1" Background="#F8F9FA"
                    BorderBrush="#DDDDDD" BorderThickness="1,0,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Titre formulaire -->
                    <Border Grid.Row="0" Background="#2C3E7A" Padding="10,8" Margin="0,0,0,20">
                        <TextBlock x:Name="TxtTitreFormulaire" Text="FORMULAIRE"
                                   Foreground="White" FontWeight="Bold"/>
                    </Border>

                    <!-- Champs -->
                    <StackPanel Grid.Row="1">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Nom Offre" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="TxtNomOffre" Padding="6,4"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Description" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="TxtDescription" Padding="6,4"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Nombre unites" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="TxtNombreUnites" Padding="6,4"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="PrixMensuel" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="TxtPrixMensuel" Padding="6,4"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Prix annuelle" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="TxtPrixAnnuelle" Padding="6,4"/>

                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Réduction annuelle" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="TxtReductionAnnuelle" Padding="6,4"/>

                        </Grid>
                        <!-- Message erreur -->
                        <TextBlock x:Name="TxtErreur" Foreground="Red"
                                   TextWrapping="Wrap" Margin="0,5,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Boutons formulaire -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="ANNULER" Padding="12,6" Margin="0,0,8,0"
                                BorderThickness="1" Click="BtnAnnuler_Click"/>
                        <Button x:Name="BtnEnregistrer" Content="ENREGISTRER"
                                Padding="12,6" Background="#2C3E7A"
                                Foreground="White" BorderThickness="0"
                                Click="BtnEnregistrer_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>